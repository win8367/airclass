<script type="text/babel">
    const { useState, useEffect } = React;

    const App = () => {
        const [students, setStudents] = useState([
            { id: 1, name: "홍길동", number: 1, consultation: [], career: "", seteuk: "", jongteuk: "" }
        ]);
        const [selectedStudentId, setSelectedStudentId] = useState(null);
        const [activeTab, setActiveTab] = useState('list');

        const addStudent = () => {
            const name = prompt("학생 이름을 입력하세요:");
            if (name) {
                const newId = students.length > 0 ? Math.max(...students.map(s => s.id)) + 1 : 1;
                setStudents([...students, { 
                    id: newId, 
                    name, 
                    number: students.length + 1, 
                    consultation: [], 
                    career: "", 
                    seteuk: "", 
                    jongteuk: "" 
                }]);
            }
        };

        const updateStudentData = (id, field, value) => {
            setStudents(students.map(s => s.id === id ? { ...s, [field]: value } : s));
        };

        const addConsultation = (id) => {
            const category = prompt("카테고리를 입력하세요 (자격증, 학과공부, 근태, 수행평가 등):");
            const content = prompt("상담 내용을 입력하세요:");
            if (category && content) {
                const student = students.find(s => s.id === id);
                const newConsults = [...student.consultation, { date: new Date().toLocaleDateString(), category, content }];
                updateStudentData(id, 'consultation', newConsults);
            }
        };

        const selectedStudent = students.find(s => s.id === selectedStudentId);

        return (
            <div className="min-h-screen flex flex-col">
                <nav className="bg-white shadow-sm px-6 py-4 flex justify-between items-center">
                    <h1 className="text-xl font-bold text-slate-800">🏫 Smart 학급관리 v1.0</h1>
                    <div className="space-x-4">
                        <button onClick={() => setActiveTab('list')} className={`px-3 py-2 text-sm font-medium ${activeTab === 'list' ? 'tab-active' : 'text-slate-500'}`}>학생 명단</button>
                        {selectedStudentId && (
                            <button onClick={() => setActiveTab('detail')} className={`px-3 py-2 text-sm font-medium ${activeTab === 'detail' ? 'tab-active' : 'text-slate-500'}`}>{selectedStudent.name} 상담기록</button>
                        )}
                    </div>
                </nav>

                <main className="flex-1 p-6 overflow-auto">
                    {activeTab === 'list' ? (
                        <div className="max-w-4xl mx-auto">
                            <div className="flex justify-between items-center mb-6">
                                <h2 className="text-2xl font-semibold text-slate-700">우리 반 학생 목록</h2>
                                <button onClick={addStudent} className="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">학생 추가</button>
                            </div>
                            <div className="bg-white rounded-xl shadow overflow-hidden">
                                <table className="w-full text-left">
                                    <thead className="bg-slate-50">
                                        <tr>
                                            <th className="px-6 py-3 text-xs font-medium text-slate-500">번호</th>
                                            <th className="px-6 py-3 text-xs font-medium text-slate-500">이름</th>
                                            <th className="px-6 py-3 text-xs font-medium text-slate-500">최근 상담</th>
                                            <th className="px-6 py-3 text-xs font-medium text-slate-500">관리</th>
                                        </tr>
                                    </thead>
                                    <tbody className="divide-y divide-slate-100">
                                        {students.map(student => (
                                            <tr key={student.id} className="hover:bg-slate-50">
                                                <td className="px-6 py-4">{student.number}</td>
                                                <td className="px-6 py-4 font-semibold text-blue-600">{student.name}</td>
                                                <td className="px-6 py-4 text-sm text-slate-500">{student.consultation.length > 0 ? student.consultation[student.consultation.length - 1].date : "기록 없음"}</td>
                                                <td className="px-6 py-4">
                                                    <button onClick={() => { setSelectedStudentId(student.id); setActiveTab('detail'); }} className="text-sm bg-slate-100 px-3 py-1 rounded">상세 보기</button>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ) : (
                        <div className="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div className="md:col-span-2 space-y-6">
                                <section className="bg-white p-6 rounded-xl shadow">
                                    <div className="flex justify-between items-center mb-4">
                                        <h3 className="text-lg font-bold">1. 개별 상담 내역</h3>
                                        <button onClick={() => addConsultation(selectedStudent.id)} className="text-sm text-blue-600">+ 추가</button>
                                    </div>
                                    <div className="space-y-3">
                                        {selectedStudent.consultation.map((c, i) => (
                                            <div key={i} className="border-l-4 border-blue-400 bg-slate-50 p-3 rounded-r-lg">
                                                <div className="flex justify-between text-xs text-slate-400 mb-1"><span>[{c.category}]</span><span>{c.date}</span></div>
                                                <p className="text-sm text-slate-700">{c.content}</p>
                                            </div>
                                        ))}
                                    </div>
                                </section>
                                <section className="bg-white p-6 rounded-xl shadow">
                                    <h3 className="text-lg font-bold mb-4">2. 진로 지도 방향</h3>
                                    <textarea value={selectedStudent.career} onChange={(e) => updateStudentData(selectedStudent.id, 'career', e.target.value)} placeholder="진로 희망 및 지도 내용을 적어주세요." className="w-full h-32 p-3 text-sm border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none" />
                                </section>
                            </div>
                            <div className="space-y-6">
                                <section className="bg-indigo-50 p-6 rounded-xl shadow-inner border border-indigo-100">
                                    <h3 className="text-lg font-bold text-indigo-800 mb-4">3. 생기부 정리</h3>
                                    <div className="mb-4">
                                        <label className="block text-xs font-bold text-indigo-600 mb-1">세특</label>
                                        <textarea value={selectedStudent.seteuk} onChange={(e) => updateStudentData(selectedStudent.id, 'seteuk', e.target.value)} placeholder="세특 기록..." className="w-full h-40 p-3 text-sm border rounded-lg outline-none" />
                                    </div>
                                    <div>
                                        <label className="block text-xs font-bold text-indigo-600 mb-1">종특</label>
                                        <textarea value={selectedStudent.jongteuk} onChange={(e) => updateStudentData(selectedStudent.id, 'jongteuk', e.target.value)} placeholder="종특 기록..." className="w-full h-40 p-3 text-sm border rounded-lg outline-none" />
                                    </div>
                                </section>
                            </div>
                        </div>
                    )}
                </main>
            </div>
        );
    };

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
</script>
